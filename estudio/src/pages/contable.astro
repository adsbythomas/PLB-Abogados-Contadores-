---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import About from '@components/About.astro';
import Areas from '@components/Areas.astro';
import Sectors from '@components/Sectors.astro';
import Team from '@components/Team.astro';
import Timeline from '@components/Timeline.astro';
import Contact from '@components/Contact.astro';
import CrossLink from '@components/CrossLink.astro';
import { accounting } from '@lib/accounting';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<BaseLayout
  practice="accounting"
  title="PLB Contable — Contabilidad e Impuestos · Buenos Aires"
  description="Área contable integral del estudio Pantarotto Lértora Bardagí: liquidación de impuestos, estados contables, auditoría, planificación fiscal, sueldos y contabilidad internacional.">

  <Hero
    practice="accounting"
    eyebrow={accounting.eyebrow}
    kicker={accounting.hero.kicker}
    title={accounting.hero.title}
    titleAccent={accounting.hero.titleAccent}
    titleSuffix={accounting.hero.titleSuffix}
    lead={accounting.hero.lead}
    ctaPrimary={accounting.hero.ctaPrimary}
    ctaSecondary={accounting.hero.ctaSecondary}
    switchHref={withBase('/')}
    switchLabel="Ver área legal"
  />

  <About
    label={accounting.about.label}
    title={accounting.about.title}
    paragraphs={accounting.about.paragraphs}
    highlights={accounting.about.highlights}
  />

  <Areas
    label={accounting.areas.label}
    title={accounting.areas.title}
    sub={accounting.areas.sub}
    items={accounting.areas.items}
  />

  <Sectors
    label={accounting.sectors.label}
    title={accounting.sectors.title}
    sub={accounting.sectors.sub}
    items={accounting.sectors.items}
  />

  <Team
    label={accounting.team.label}
    title={accounting.team.title}
    sub={accounting.team.sub}
    members={accounting.team.members}
    ctaText={accounting.team.ctaText}
  />

  <Timeline
    label={accounting.timeline.label}
    title={accounting.timeline.title}
    items={accounting.timeline.items}
  />

  <CrossLink practice="accounting" />

  <Contact
    label={accounting.contact.label}
    title={accounting.contact.title}
    titleAccent={accounting.contact.titleAccent}
    desc={accounting.contact.desc}
    formAreas={accounting.contact.formAreas}
    formAreaLabel="Servicio requerido"
  />
</BaseLayout>
