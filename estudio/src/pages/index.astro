---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import About from '@components/About.astro';
import Areas from '@components/Areas.astro';
import Sectors from '@components/Sectors.astro';
import Team from '@components/Team.astro';
import Timeline from '@components/Timeline.astro';
import Contact from '@components/Contact.astro';
import CrossLink from '@components/CrossLink.astro';
import { legal } from '@lib/legal';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<BaseLayout
  practice="legal"
  title="PLB Abogados — Derecho Empresarial en Buenos Aires · 20 años"
  description="Estudio integral de abogados y contadores en Buenos Aires, con corresponsales en EE.UU. y Uruguay. Tributario, aduanero, societario, laboral, aerocomercial y penal económico.">

  <Hero
    practice="legal"
    eyebrow={legal.eyebrow}
    kicker={legal.hero.kicker}
    title={legal.hero.title}
    titleAccent={legal.hero.titleAccent}
    titleSuffix={legal.hero.titleSuffix}
    lead={legal.hero.lead}
    ctaPrimary={legal.hero.ctaPrimary}
    ctaSecondary={legal.hero.ctaSecondary}
    switchHref={withBase('/contable')}
    switchLabel="Ver área contable"
  />

  <About
    label={legal.about.label}
    title={legal.about.title}
    paragraphs={legal.about.paragraphs}
    highlights={legal.about.highlights}
  />

  <Areas
    label={legal.areas.label}
    title={legal.areas.title}
    sub={legal.areas.sub}
    items={legal.areas.items}
  />

  <Sectors
    label={legal.sectors.label}
    title={legal.sectors.title}
    sub={legal.sectors.sub}
    items={legal.sectors.items}
  />

  <Team
    label={legal.team.label}
    title={legal.team.title}
    sub={legal.team.sub}
    members={legal.team.members}
    ctaText={legal.team.ctaText}
  />

  <Timeline
    label={legal.timeline.label}
    title={legal.timeline.title}
    items={legal.timeline.items}
  />

  <CrossLink practice="legal" />

  <Contact
    label={legal.contact.label}
    title={legal.contact.title}
    titleAccent={legal.contact.titleAccent}
    desc={legal.contact.desc}
    formAreas={legal.contact.formAreas}
    formAreaLabel="Área de consulta"
  />
</BaseLayout>
