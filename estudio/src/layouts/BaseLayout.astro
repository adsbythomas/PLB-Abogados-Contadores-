---
import '../styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import type { Practice } from '@lib/site';

export interface Props {
  title: string;
  description: string;
  practice: Practice;
  canonical?: string;
}

const { title, description, practice, canonical } = Astro.props;
const themeClass = practice === 'legal' ? 'theme-legal' : 'theme-accounting';
const themeColor = practice === 'legal' ? '#1a3a6c' : '#80371c';
---
<!doctype html>
<html lang="es" class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='10' fill='${encodeURIComponent(themeColor)}'/><text x='50%25' y='55%25' font-family='Georgia,serif' font-size='28' font-weight='700' text-anchor='middle' dominant-baseline='middle' fill='%23ffffff'>PLB</text></svg>`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Inter:wght@400;500;600;700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': practice === 'legal' ? 'LegalService' : 'AccountingService',
      name: 'Pantarotto Lértora Bardagí & Asocs.',
      alternateName: 'PLB & Asocs.',
      description,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Av. Corrientes 1464, Piso 16 Of. 1605',
        postalCode: 'C1042',
        addressLocality: 'Buenos Aires',
        addressCountry: 'AR',
      },
      areaServed: [
        { '@type': 'Country', name: 'Argentina' },
        { '@type': 'Country', name: 'United States' },
        { '@type': 'Country', name: 'Uruguay' },
      ],
      foundingDate: '2004',
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:bg-white focus:px-4 focus:py-2 focus:z-50">Saltar al contenido</a>
    <Nav practice={practice} />
    <main id="main"><slot /></main>
    <Footer practice={practice} />
    <script>
      // Reveal on scroll — animación sutil al entrar en viewport
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // Nav scroll state
      const nav = document.getElementById('mainNav');
      const onScroll = () => {
        if (!nav) return;
        if (window.scrollY > 8) nav.classList.add('scrolled');
        else nav.classList.remove('scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Mobile menu
      const openBtn = document.getElementById('mob-open');
      const closeBtn = document.getElementById('mob-close');
      const mob = document.getElementById('mob');
      openBtn?.addEventListener('click', () => mob?.classList.add('open'));
      closeBtn?.addEventListener('click', () => mob?.classList.remove('open'));
      mob?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => mob.classList.remove('open')));

      // Form feedback (demo — sin backend)
      document.querySelectorAll('form[data-contact]')?.forEach((form) => {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const btn = form.querySelector('button[type="submit"]');
          if (btn) {
            btn.textContent = 'Consulta enviada · Gracias';
            btn.setAttribute('disabled', 'true');
            btn.classList.add('sent');
          }
        });
      });
    </script>
    <style is:global>
      #mob { display: none; }
      #mob.open { display: flex; }
      nav.scrolled { box-shadow: 0 1px 0 rgba(0,0,0,0.06), 0 12px 30px -24px rgba(0,0,0,0.2); }
      .sent { background: #2d6b3b !important; }
    </style>
  </body>
</html>
