---
import { site } from '@lib/site';
import type { Practice } from '@lib/site';

export interface Props { practice: Practice }
const { practice } = Astro.props;
const isLegal = practice === 'legal';

const base = import.meta.env.BASE_URL; // respeta base path (GitHub Pages)
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;

const navLinks = isLegal
  ? [
      { href: '#nosotros', label: 'El estudio' },
      { href: '#areas', label: 'Áreas' },
      { href: '#equipo', label: 'Equipo' },
      { href: '#historia', label: 'Trayectoria' },
      { href: '#contacto', label: 'Contacto' },
    ]
  : [
      { href: '#nosotros', label: 'El área' },
      { href: '#areas', label: 'Servicios' },
      { href: '#equipo', label: 'Equipo' },
      { href: '#historia', label: 'Trayectoria' },
      { href: '#contacto', label: 'Contacto' },
    ];

const switchHref  = isLegal ? withBase('/contable') : withBase('/');
const switchLabel = isLegal ? 'Área contable'      : 'Área legal';
const switchClass = isLegal
  ? 'bg-ledger-700 hover:bg-ledger-800 text-white'
  : 'bg-legal-700  hover:bg-legal-800  text-white';
---
<nav id="mainNav" class="fixed inset-x-0 top-0 z-50 bg-paper/95 backdrop-blur border-b border-ink-200/70 transition-shadow">
  <div class="shell h-[72px] flex items-center justify-between gap-6">
    <a href={withBase('/')} class="flex items-baseline gap-2 text-ink-900 no-underline">
      <span class="font-serif text-2xl font-semibold tracking-tight">
        {site.abbr.a}<span style="color: var(--brand-700)">{site.abbr.b}</span>
      </span>
      <span class="hidden md:inline w-px h-5 bg-ink-200"></span>
      <span class="hidden md:inline text-[0.78rem] text-ink-500 max-w-[220px] leading-tight">
        Pantarotto Lértora Bardagí<br/>& Asociados
      </span>
    </a>

    <ul class="hidden lg:flex items-center gap-7">
      {navLinks.map((l) => (
        <li>
          <a href={l.href}
             class="text-[0.72rem] uppercase tracking-[0.16em] text-ink-700 hover:text-ink-900 transition relative group">
            {l.label}
            <span class="absolute left-0 -bottom-1 h-[2px] w-0 group-hover:w-full transition-all duration-300" style="background: var(--brand-700)"></span>
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a href={switchHref}
         class={`hidden md:inline-flex px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.14em] ${switchClass}`}>
        {switchLabel}
      </a>
      <button id="mob-open" class="lg:hidden w-10 h-10 border border-ink-300 grid place-items-center" aria-label="Abrir menú">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M1 1h16M1 7h16M1 13h16"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<div id="mob" class="fixed inset-0 z-[60] bg-paper flex-col hidden">
  <div class="shell flex justify-between items-center h-[72px]">
    <span class="font-serif text-2xl font-semibold">{site.abbr.a}<span style="color: var(--brand-700)">{site.abbr.b}</span></span>
    <button id="mob-close" aria-label="Cerrar menú" class="text-3xl leading-none text-ink-600">×</button>
  </div>
  <nav class="shell flex-1 py-8 flex flex-col gap-1">
    {navLinks.map((l) => (
      <a href={l.href} class="text-xl font-serif font-semibold py-4 border-b border-ink-200 text-ink-900">{l.label}</a>
    ))}
    <a href={switchHref} class={`mt-6 inline-flex self-start px-5 py-3 text-[0.78rem] font-semibold uppercase tracking-[0.14em] ${switchClass}`}>
      {switchLabel}
    </a>
  </nav>
</div>

<div class="h-[72px]"></div>
