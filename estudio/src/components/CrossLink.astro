---
import type { Practice } from '@lib/site';

export interface Props { practice: Practice; }
const { practice } = Astro.props;
const isLegal = practice === 'legal';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;

const href      = isLegal ? withBase('/contable') : withBase('/');
const eyebrow   = isLegal ? 'Área contable del estudio' : 'Área legal del estudio';
const title     = isLegal
  ? 'Contabilidad, auditoría e impuestos'
  : 'Asesoramiento jurídico para empresas';
const desc      = isLegal
  ? 'El equipo contable acompaña al área legal en reestructuraciones, due diligence, planificación fiscal y cumplimiento. Coordinación permanente entre ambas prácticas.'
  : 'El estudio integra el área legal con seis prácticas de derecho empresarial. Coordinación permanente para soluciones jurídico-contables unificadas.';
const ctaLabel  = isLegal ? 'Ir al área contable' : 'Ir al área legal';
const accentBg  = isLegal ? 'bg-ledger-700' : 'bg-legal-700';
const accentFg  = isLegal ? 'bg-ledger-50 text-ledger-900 border-ledger-200' : 'bg-legal-50 text-legal-900 border-legal-200';
const accentDot = isLegal ? 'bg-ledger-500' : 'bg-legal-500';
---
<section class="border-t border-ink-200 py-20 reveal">
  <div class="shell">
    <div class={`relative overflow-hidden border ${accentFg} p-10 md:p-14 grid md:grid-cols-[auto_1fr_auto] gap-8 items-center`}>
      <span class={`w-3 h-3 rounded-full ${accentDot}`} aria-hidden="true"></span>
      <div>
        <div class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] mb-2 opacity-70">{eyebrow}</div>
        <h3 class="font-serif font-semibold text-2xl md:text-3xl leading-tight">{title}</h3>
        <p class="mt-3 text-[0.95rem] leading-relaxed max-w-prose-lg opacity-80">{desc}</p>
      </div>
      <a href={href} class={`inline-flex items-center gap-3 px-6 py-4 text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-white ${accentBg} hover:opacity-90 transition whitespace-nowrap`}>
        {ctaLabel}
        <svg width="16" height="12" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 5h12M9 1l4 4-4 4"/></svg>
      </a>
    </div>
  </div>
</section>
