---
export interface Area { key: string; name: string; desc: string; }
export interface Props {
  label: string;
  title: string;
  sub: string;
  items: Area[];
}
const { label, title, sub, items } = Astro.props;

// Íconos por área (SVG) — se renderizan en la columna sticky al hover
const icons: Record<string, string> = {
  tributario:    '<circle cx="40" cy="28" r="6"/><path d="M20 70 Q40 40 60 70" /><path d="M8 78 L72 78"/><path d="M22 78 V52 M58 78 V52"/>',
  aduanero:      '<rect x="12" y="30" width="56" height="40" rx="2"/><path d="M12 40h56M26 30v40M54 30v40"/><path d="M18 20l8-10h28l8 10"/>',
  laboral:       '<circle cx="40" cy="26" r="10"/><path d="M18 72 Q40 50 62 72"/><path d="M30 72 V60 M50 72 V60"/>',
  societario:    '<rect x="18" y="20" width="44" height="56" rx="1"/><path d="M28 30h8M44 30h8M28 42h8M44 42h8M28 54h8M44 54h8"/><path d="M36 76 H44 V66 H36z"/>',
  aerocomercial: '<path d="M8 50 L50 30 L72 18 L62 42 L40 56 L32 70 L28 56 L14 60 Z"/><path d="M50 30 L36 52"/>',
  penal:         '<path d="M14 24 L38 12 L62 24"/><rect x="16" y="24" width="44" height="10" rx="1"/><path d="M28 34 V74 M48 34 V74"/><path d="M12 74 H64"/><circle cx="38" cy="54" r="4"/>',
  // fallback genérico
  default:       '<circle cx="40" cy="40" r="24"/><path d="M26 40 L36 50 L54 30"/>',
  // contables
  impuestos:     '<rect x="14" y="14" width="52" height="56" rx="2"/><path d="M22 28h36M22 40h24M22 52h18"/><path d="M50 56l10-10 6 6-10 10z"/>',
  estados:       '<path d="M14 72 V22 M14 72 H68"/><rect x="22" y="52" width="8" height="18"/><rect x="36" y="40" width="8" height="30"/><rect x="50" y="28" width="8" height="42"/>',
  auditoria:     '<circle cx="36" cy="36" r="20"/><path d="M50 50 L68 68"/><path d="M28 36 L34 42 L46 28"/>',
  planificacion: '<path d="M10 64 L26 40 L38 50 L60 22"/><path d="M50 22 H62 V34"/><path d="M10 72 H70"/>',
  sueldos:       '<rect x="12" y="22" width="56" height="40" rx="2"/><path d="M12 34h56"/><circle cx="26" cy="48" r="5"/><path d="M40 44h18M40 52h14"/>',
  internacional: '<circle cx="40" cy="40" r="24"/><path d="M16 40h48M40 16c8 8 8 40 0 48M40 16c-8 8-8 40 0 48"/>',
};
---
<section id="practica" class="relative py-28 md:py-32 reveal">
  <div class="shell grid md:grid-cols-[1fr_1.8fr] gap-12 md:gap-20">
    <!-- Columna sticky con título + ícono dinámico que cambia al hover -->
    <aside class="md:sticky md:top-28 self-start">
      <div class="section-kicker"><span>{label}</span></div>
      <h2 class="font-sans font-bold text-cover text-ink-900 leading-[1.05]">
        <span class="stack-line inline-block" data-stack-line><span>{title}</span></span>
      </h2>
      <p class="mt-6 text-ink-600 max-w-md leading-relaxed">{sub}</p>

      <!-- Ícono grande que cambia al hacer hover en cada área -->
      <div class="mt-10 hidden md:block">
        <div class="relative w-[280px] aspect-square border border-ink-200 bg-paperDark/30">
          {items.map((a, i) => (
            <svg
              data-area-icon={a.key}
              viewBox="0 0 80 80"
              class="absolute inset-0 w-full h-full p-12 opacity-0 transition-opacity duration-500"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`color: var(--brand-700); ${i === 0 ? 'opacity:1;' : ''}`}
              set:html={icons[a.key] || icons.default}
            />
          ))}
          <!-- Label del área activa -->
          <div class="absolute bottom-4 left-4 font-mono text-tick uppercase tracking-tick text-ink-400" data-area-label>
            {items[0].name}
          </div>
          <!-- Contador -->
          <div class="absolute top-4 right-4 font-mono text-tick uppercase tracking-tick text-ink-400">
            <span data-index-count>01</span> / {String(items.length).padStart(2, '0')}
          </div>
        </div>
      </div>
    </aside>

    <!-- Lista de áreas -->
    <div class="space-y-0" data-index>
      {items.map((a, i) => (
        <a href="#contacto"
           class="block index-row group"
           data-index-item
           data-area-key={a.key}
           data-area-name={a.name}>
          <span class="index-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <span class="index-name">{a.name}</span>
            <p class="index-desc">{a.desc}</p>
          </div>
          <span class="index-arrow">Consultar →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Sincroniza el ícono + label de la columna sticky con el área sobre la que está el mouse.
  const items = document.querySelectorAll('[data-index-item]');
  const icons = document.querySelectorAll('[data-area-icon]');
  const count = document.querySelector('[data-index-count]');
  const label = document.querySelector('[data-area-label]');

  items.forEach((it, i) => {
    it.addEventListener('mouseenter', () => {
      const key = it.getAttribute('data-area-key');
      const name = it.getAttribute('data-area-name');
      icons.forEach((icon) => {
        const match = icon.getAttribute('data-area-icon') === key;
        (icon as HTMLElement).style.opacity = match ? '1' : '0';
      });
      if (count) count.textContent = String(i + 1).padStart(2, '0');
      if (label && name) label.textContent = name;
    });
  });
</script>
