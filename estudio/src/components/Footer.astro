---
import { site } from '@lib/site';
import type { Practice } from '@lib/site';

export interface Props { practice: Practice }
const { practice } = Astro.props;
const isLegal = practice === 'legal';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
const year = new Date().getFullYear();
---
<footer class="relative mt-24 border-t border-ink-200 bg-parchment">
  <div class="shell py-16 grid gap-12 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <div class="font-serif text-2xl font-semibold">
        {site.abbr.a}<span style="color: var(--brand-700)">{site.abbr.b}</span> & Asocs.
      </div>
      <p class="mt-3 text-sm text-ink-600 max-w-xs leading-relaxed">
        Pantarotto Lértora Bardagí & Asociados — Abogados & Contadores Públicos.
        Buenos Aires · Estados Unidos · Uruguay.
      </p>
      <a href={site.linkedin} target="_blank" rel="noopener"
         class="mt-5 inline-flex items-center gap-2 text-[0.72rem] uppercase tracking-[0.14em] text-ink-700 hover:text-ink-900">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4.98 3.5a2.5 2.5 0 11.02 5.001 2.5 2.5 0 01-.02-5.001zM3 9h4v12H3zM14.5 9c-2.43 0-3.5 1.5-3.5 3V21h-4V9h4v1.7c.7-.9 2-1.7 3.5-1.7 3 0 4.5 2 4.5 5.2V21h-4v-6.5c0-1.5-.5-2.5-2-2.5z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <div>
      <h4 class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-ink-500 mb-4">El estudio</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={withBase('/')} class="text-ink-700 hover:text-ink-900">Área legal</a></li>
        <li><a href={withBase('/contable')} class="text-ink-700 hover:text-ink-900">Área contable</a></li>
        <li><a href="#equipo" class="text-ink-700 hover:text-ink-900">Equipo</a></li>
        <li><a href="#historia" class="text-ink-700 hover:text-ink-900">Trayectoria</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-ink-500 mb-4">Práctica</h4>
      <ul class="space-y-2 text-sm">
        {(isLegal
          ? ['Tributario', 'Aduanero', 'Laboral', 'Societario', 'Aerocomercial', 'Penal Económico']
          : ['Liquidación de Impuestos', 'Estados Contables', 'Auditoría', 'Planificación Impositiva', 'Sueldos', 'Contabilidad Internacional']
        ).map((a) => <li><a href="#areas" class="text-ink-700 hover:text-ink-900">{a}</a></li>)}
      </ul>
    </div>

    <div>
      <h4 class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-ink-500 mb-4">Contacto</h4>
      <address class="not-italic text-sm text-ink-700 leading-relaxed">
        {site.address.line1}<br/>
        {site.address.line2}<br/>
        {site.address.postalCode} · {site.address.city}
      </address>
      <p class="mt-3 text-sm text-ink-600">{site.hours}</p>
    </div>
  </div>

  <div class="hairline">
    <div class="shell py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-ink-500">
      <span>© {year} {site.firmName} · Todos los derechos reservados.</span>
      <div class="flex items-center gap-4">
        <a href="#" class="hover:text-ink-900">Política de privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="#" class="hover:text-ink-900">Términos de uso</a>
      </div>
    </div>
  </div>
</footer>
