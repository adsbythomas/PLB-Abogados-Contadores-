---
export interface Item { year: string; title: string; desc: string; }
export interface Props { label: string; title: string; items: Item[]; }
const { label, title, items } = Astro.props;
---
<section id="historia" class="bg-ink-900 text-paper py-24 md:py-32 reveal">
  <div class="shell">
    <header class="max-w-3xl mb-16">
      <div class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] mb-3" style="color: var(--brand-300)">{label}</div>
      <h2 class="font-serif font-semibold text-h2 text-paper">{title}</h2>
    </header>

    <ol class="timeline-rail space-y-12">
      {items.map((it, i) => {
        const left = i % 2 === 0;
        return (
          <li class="relative grid md:grid-cols-2 items-start gap-6 md:gap-16">
            <div class={`md:${left ? 'order-1 text-right pr-10' : 'order-2 text-left pl-10'} pl-10 md:pl-0`}>
              <div class="font-serif font-semibold text-3xl" style="color: var(--brand-300)">{it.year}</div>
              <h3 class="mt-2 font-serif font-semibold text-xl text-paper">{it.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-paper/70">{it.desc}</p>
            </div>
            <div class={`hidden md:block ${left ? 'order-2' : 'order-1'}`}></div>

            <span class="absolute top-2 md:top-4 left-[12px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 rounded-full ring-4 ring-ink-900" style="background: var(--brand-500)"></span>
          </li>
        );
      })}
    </ol>
  </div>
</section>
