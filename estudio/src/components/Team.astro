---
export interface Member { initials: string; name: string; role: string; spec: string; }
export interface Props {
  label: string;
  title: string;
  sub: string;
  members: Member[];
  ctaText: string;
}
const { label, title, sub, members, ctaText } = Astro.props;
---
<section id="equipo" class="border-t border-ink-200 py-24 md:py-32 reveal">
  <div class="shell">
    <header class="max-w-3xl mb-14">
      <div class="eyebrow mb-3">{label}</div>
      <h2 class="section-title">{title}</h2>
      <p class="mt-4 text-ink-600 leading-relaxed">{sub}</p>
    </header>

    <div class="grid gap-px bg-ink-200 border border-ink-200 md:grid-cols-2 lg:grid-cols-4">
      {members.map((m) => (
        <article class="bg-white p-7 md:p-8 flex flex-col gap-5 transition hover:bg-paper">
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 rounded-full grid place-items-center text-white font-serif font-semibold text-lg"
                 style="background: var(--brand-700)">
              {m.initials}
            </div>
            <div>
              <div class="font-serif font-semibold text-lg text-ink-900">{m.name}</div>
              <div class="text-[0.68rem] font-semibold uppercase tracking-[0.16em]" style="color: var(--brand-700)">{m.role}</div>
            </div>
          </div>
          <p class="text-sm text-ink-600 leading-relaxed">{m.spec}</p>
        </article>
      ))}

      <article class="bg-parchment p-7 md:p-8 flex flex-col justify-center items-start gap-4 border-2 border-dashed border-ink-200">
        <div class="font-serif text-3xl text-ink-300 leading-none">+</div>
        <p class="text-sm text-ink-700 leading-relaxed">{ctaText}</p>
        <a href="#contacto" class="inline-flex items-center gap-2 text-[0.72rem] font-semibold uppercase tracking-[0.14em]" style="color: var(--brand-700)">
          Contactar al equipo
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 5h12M9 1l4 4-4 4"/></svg>
        </a>
      </article>
    </div>
  </div>
</section>
